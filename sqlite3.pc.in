# Package Information for pkg-config
# PQLite - Post-Quantum SQLite
# Copyright (c) 2025-2026 Dyber, Inc.

prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: PQLite
Description: Post-Quantum SQLite - Quantum-resistant database encryption
Version: @PACKAGE_VERSION@
Libs: -L${libdir} -lpqlite3
Libs.private: @LDFLAGS_MATH@ @LDFLAGS_ZLIB@ @LDFLAGS_DLOPEN@ @LDFLAGS_PTHREAD@ @LDFLAGS_ICU@
Cflags: -I${includedir}
